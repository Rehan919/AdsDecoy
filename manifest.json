{
  "manifest_version": 3,
  "name": "Digital Decoy",
  "description": "Privacy-first browser extension that blocks known trackers, shows blocked companies, scores site privacy, and can optionally add browsing noise.",
  "version": "0.2.0",
  "permissions": [
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "storage",
    "tabs",
    "browsingData",
    "webRequest",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/tracker_detector.js"
  },
  "action": {
    "default_title": "Digital Decoy",
    "default_popup": "popup/popup.html"
  }
}
